<script>
(function(){
  // Default to red head guard image
  var img = document.getElementById('headguard-img');
  var td = document.getElementById('headguard-red-data');
  if (img && td) img.src = 'data:image/webp;base64,' + td.value.replace(/\s/g,'');
})();
</script>


<style>
  /* CART */
  #cart-btn { position:fixed; bottom:1.5rem; right:1.5rem; z-index:900; background:#C8102E; color:white; width:60px; height:60px; border-radius:50%; border:none; font-size:1.5rem; cursor:pointer; box-shadow:0 4px 20px rgba(200,16,46,0.6); }
  #cart-count { position:absolute; top:-4px; right:-4px; background:white; color:#C8102E; border-radius:50%; width:20px; height:20px; font-size:0.7rem; font-weight:bold; display:none; align-items:center; justify-content:center; font-family:sans-serif; }
  #cart-back { position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:901; display:none; }
  #cart-box { position:fixed; top:0; right:0; bottom:0; width:380px; max-width:100vw; background:#0D1F3C; z-index:902; transform:translateX(100%); transition:transform 0.3s; display:flex; flex-direction:column; border-left:2px solid #C8102E; }
  #cart-box.open { transform:translateX(0); }
  #cart-back.open { display:block; }
  #cart-head { padding:1.5rem; border-bottom:1px solid rgba(255,255,255,0.1); display:flex; justify-content:space-between; align-items:center; }
  #cart-head h3 { margin:0; font-family:sans-serif; color:white; font-size:1.3rem; }
  #cart-x { background:none; border:none; color:white; font-size:1.5rem; cursor:pointer; }
  #cart-list { flex:1; overflow-y:auto; padding:1rem; color:white; font-family:sans-serif; }
  #cart-foot { padding:1.5rem; border-top:1px solid rgba(255,255,255,0.1); }
  #cart-total-line { display:flex; justify-content:space-between; color:white; font-family:sans-serif; font-size:1.2rem; margin-bottom:1rem; }
  #cart-order-btn { width:100%; background:#C8102E; color:white; border:none; padding:1rem; font-size:1rem; cursor:pointer; border-radius:4px; font-family:sans-serif; font-weight:bold; }
  #cart-order-btn:hover { background:#e8192e; }
</style>

<button id="cart-btn" onclick="cartOpen()">🛒<span id="cart-count">0</span></button>
<div id="cart-back" onclick="cartClose()"></div>
<div id="cart-box">
  <div id="cart-head">
    <h3>🛒 Your Cart</h3>
    <button id="cart-x" onclick="cartClose()">✕</button>
  </div>
  <div id="cart-list">Your cart is empty.</div>
  <div id="cart-foot">
    <div id="cart-total-line"><span>Total</span><span id="cart-total">£0.00</span></div>
    <button id="cart-order-btn" onclick="cartOrder()">✅ Place Order</button>
  </div>
</div>

<script>
var C = [];
function cartOpen() {
  document.getElementById('cart-box').classList.add('open');
  document.getElementById('cart-back').classList.add('open');
}
function cartClose() {
  document.getElementById('cart-box').classList.remove('open');
  document.getElementById('cart-back').classList.remove('open');
}
function cartAdd(btn) {
  var card = btn.closest('.shop-product-card');
  var name = card.querySelector('.shop-product-name').textContent;
  var priceEl = card.querySelector('.shop-product-price');
  var price = parseFloat(priceEl.textContent.replace('£','')) || 0;
  var sel = card.querySelector('select');
  var size = '';
  if (sel) {
    if (!sel.value) { sel.style.borderColor='red'; sel.focus(); return; }
    size = sel.value;
    sel.style.borderColor = '';
  }
  C.push({name:name, price:price, size:size});
  cartRender();
  cartOpen();
}
function cartRemove(i) { C.splice(i,1); cartRender(); }
function cartRender() {
  var el = document.getElementById('cart-list');
  var cnt = document.getElementById('cart-count');
  var tot = document.getElementById('cart-total');
  if (!el) return;
  if (C.length === 0) {
    el.innerHTML = 'Your cart is empty.';
    cnt.style.display = 'none';
    tot.textContent = '£0.00';
    return;
  }
  var sum = 0; var h = '';
  C.forEach(function(item,i){
    sum += item.price;
    h += '<div style="padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;justify-content:space-between;align-items:center;">' +
      '<div><strong>' + item.name + '</strong>' + (item.size?'<br><small>'+item.size+'</small>':'') + '<br>£' + item.price.toFixed(2) + '</div>' +
      '<button onclick="cartRemove('+i+')" style="background:none;border:none;color:#aaa;cursor:pointer;font-size:1.2rem;">✕</button></div>';
  });
  el.innerHTML = h;
  cnt.textContent = C.length;
  cnt.style.display = 'flex';
  tot.textContent = '£' + sum.toFixed(2);
}
function cartOrder() {
  if (C.length === 0) return;
  var items = C.map(function(i){ return i.name + (i.size?' ('+i.size+')':'') + ' = £' + i.price.toFixed(2); });
  var total = C.reduce(function(s,i){ return s+i.price; },0);
  var fd = new FormData();
  fd.append('form_type','Shop Order');
  fd.append('_subject','Elite TKD Shop Order — £'+total.toFixed(2));
  fd.append('_replyto','elitetkdscot@gmail.com');
  fd.append('order_items',items.join(' | '));
  fd.append('order_total','£'+total.toFixed(2));
  fetch('https://formspree.io/f/mykazerd',{method:'POST',body:fd,headers:{'Accept':'application/json'}})
    .then(function(r){
      if(r.ok){
        document.getElementById('cart-list').innerHTML = '<div style="text-align:center;padding:2rem;"><div style="font-size:3rem;">✅</div><h3 style="color:white;margin:1rem 0;">Order Sent!</h3><p style="color:#aaa;">Master Divine will be in touch within 24 hours.</p></div>';
        C=[];
        document.getElementById('cart-count').style.display='none';
        document.getElementById('cart-total').textContent='£0.00';
      }
    });
}
</script>


