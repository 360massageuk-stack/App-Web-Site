<!-- ═══ CART FLOATING BUTTON ═══ -->
<button class="cart-icon-btn" onclick="openCart()" title="View Cart" aria-label="Shopping Cart">
  🛒
  <span class="cart-badge" id="cart-badge">0</span>
</button>

<!-- ═══ CART TOAST ═══ -->
<div class="cart-added-toast" id="cart-toast">✓ Added to cart</div>

<!-- ═══ CART BACKDROP ═══ -->
<div class="cart-backdrop" id="cart-backdrop" onclick="closeCart()"></div>

<!-- ═══ CART DRAWER ═══ -->
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-header">
    <h3>🛒 Your Cart</h3>
    <button class="cart-close-btn" onclick="closeCart()">✕</button>
  </div>

  <div class="cart-items" id="cart-items">
    <div class="cart-empty" id="cart-empty">
      <span class="cart-empty-icon">🛒</span>
      Your cart is empty.<br>Add a uniform or item from the shop to get started.
    </div>
  </div>

  <div class="cart-footer">
    <div class="cart-total-row">
      <span class="cart-total-label">Total</span>
      <span class="cart-total-amount" id="cart-total">£0.00</span>
    </div>

    <button onclick="submitOrderEmailOnly()"
      style="display:block;width:100%;text-align:center;background:#C8102E;color:white;font-family:'Oswald',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.1em;text-transform:uppercase;padding:1rem;border-radius:6px;margin-bottom:0.75rem;border:none;cursor:pointer;">
      ✅ Place Order
    </button>

    <p class="cart-checkout-note">
      Clicking Place Order sends your order to Master Divine by email.<br>
      You will receive payment instructions by return email within 24 hours.<br>
      <strong style="color:var(--off-white);">elitetkdscot@gmail.com · 07590 283735</strong>
    </p>
  </div>
</div>
