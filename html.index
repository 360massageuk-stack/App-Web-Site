<section id="app" style="background:var(--navy-mid);">
  <div class="section-inner">

    <div class="reveal" style="text-align:center;max-width:700px;margin:0 auto 3.5rem;">
      <div class="section-label" style="justify-content:center;">Train Smarter</div>
      <h2 class="section-title">THE ELITE<br><span class="red">TKD APP</span></h2>
      <p style="color:var(--off-white);font-size:1.05rem;line-height:1.75;opacity:0.9;">Your complete Taekwon-Do training companion — designed by Master Dutton for Elite Scotland students. Everything you need to train, grade and improve, right in your pocket.</p>
    </div>

    <!-- Feature grid -->
    <div class="reveal app-features-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:3rem;">

      <div style="background:var(--navy);border:1px solid rgba(200,16,46,0.2);border-radius:6px;padding:1.5rem;">
        <div style="font-size:2rem;margin-bottom:0.75rem;">🥋</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;color:var(--white);margin-bottom:0.4rem;">Patterns</div>
        <p style="font-size:0.85rem;color:var(--gray);line-height:1.6;">Full video library of all ITF patterns (Tuls) from white belt to black belt. Step-by-step breakdowns with Master Dutton.</p>
      </div>

      <div style="background:var(--navy);border:1px solid rgba(200,16,46,0.2);border-radius:6px;padding:1.5rem;">
        <div style="font-size:2rem;margin-bottom:0.75rem;">📖</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;color:var(--white);margin-bottom:0.4rem;">Theory</div>
        <p style="font-size:0.85rem;color:var(--gray);line-height:1.6;">Complete grading theory for every belt level. History, philosophy and rules of Taekwon-Do — all in one place.</p>
      </div>

      <div style="background:var(--navy);border:1px solid rgba(200,16,46,0.2);border-radius:6px;padding:1.5rem;">
        <div style="font-size:2rem;margin-bottom:0.75rem;">🇰🇷</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;color:var(--white);margin-bottom:0.4rem;">Terminology</div>
        <p style="font-size:0.85rem;color:var(--gray);line-height:1.6;">Korean terminology for all techniques, commands and counting — essential for grading examinations.</p>
      </div>

      <div style="background:var(--navy);border:1px solid rgba(200,16,46,0.2);border-radius:6px;padding:1.5rem;">
        <div style="font-size:2rem;margin-bottom:0.75rem;">🎬</div>
