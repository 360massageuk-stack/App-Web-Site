<!-- ═══════════════ SHOP ═══════════════ -->

<script>
/* ═══════════════════════════════════════════════════════
   ELITE SCOTLAND TAEKWON-DO — Site JavaScript
   Formspree endpoint: https://formspree.io/f/mykazerd
   ═══════════════════════════════════════════════════════ */

const FORMSPREE_URL = 'https://formspree.io/f/mykazerd';

// ── Mobile menu ──
function toggleMenu() { document.getElementById('mobileMenu').classList.toggle('open'); }
function closeMenu()  { document.getElementById('mobileMenu').classList.remove('open'); }
document.addEventListener('click', function(e) {
  if (!e.target.closest('nav') && !e.target.closest('#mobileMenu')) closeMenu();
});

// ── Location tab switcher ──
function showLocation(loc, btn) {
  document.querySelectorAll('.loc-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.loc-tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + loc).classList.add('active');
  if (btn) {
    btn.classList.add('active');
  } else {
    document.querySelectorAll('.loc-tab-btn').forEach(b => {
      if (b.getAttribute('onclick') && b.getAttribute('onclick').includes("'" + loc + "'"))
        b.classList.add('active');
    });
  }
}

// ── Modal open / close ──
function openModal(id) {
  const modal = document.getElementById(id);
  if (!modal) return;
  // Reset the form to clean state each time it opens
  const form = modal.querySelector('form');
  const successEl = modal.querySelector('.form-success');
  const errorBanner = modal.querySelector('.form-error-banner');
  if (form) {
    form.style.display = '';
    form.reset();
    clearFormErrors(form);
  }
  if (successEl) successEl.style.display = 'none';
  if (errorBanner) errorBanner.remove();
  modal.classList.add('open');
  // Focus first input for accessibility
  setTimeout(() => { const f = modal.querySelector('input:not([type=hidden])'); if (f) f.focus(); }, 100);
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}
function closeModalOutside(e, id) {
  if (e.target === document.getElementById(id)) closeModal(id);
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.querySelectorAll('.modal-overlay.open').forEach(m => {
      m.classList.remove('open');
        });
  }
});

// ── Form validation helpers ──
function clearFormErrors(form) {
  form.querySelectorAll('.field-error').forEach(el => el.remove());
  form.querySelectorAll('[aria-invalid]').forEach(el => el.removeAttribute('aria-invalid'));
  form.querySelectorAll('.form-group.has-error').forEach(el => el.classList.remove('has-error'));
}

function showFieldError(input, message) {
  const group = input.closest('.form-group') || input.closest('.consent-row');
  if (!group) return;
  group.classList.add('has-error');
  input.setAttribute('aria-invalid', 'true');
  if (!group.querySelector('.field-error')) {
    const err = document.createElement('span');
    err.className = 'field-error';
    err.textContent = message;
    group.appendChild(err);
  }
}

function validateForm(form) {
  clearFormErrors(form);
  let valid = true;
  form.querySelectorAll('[required]').forEach(field => {
    const val = field.type === 'checkbox' ? field.checked : field.value.trim();
    if (!val) {
      const label = form.querySelector(`label[for="${field.id}"]`);
      const labelText = label ? label.textContent.replace('*','').trim() : 'This field';
      showFieldError(field, `${labelText} is required.`);
      valid = false;
    } else if (field.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
      showFieldError(field, 'Please enter a valid email address.');
      valid = false;
    }
  });
  // Scroll to first error
  const firstErr = form.querySelector('.has-error');
  if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
  return valid;
}

// ── Modal form submit handler (all 8 modal forms) ──
async function handleFormSubmit(e, modalId) {
  e.preventDefault();
  const form = e.target;
  const btn = form.querySelector('button[type="submit"]');
  const successEl = document.getElementById('success-' + modalId);
  const origLabel = btn.innerHTML;

  if (!validateForm(form)) return;

  btn.disabled = true;
  btn.innerHTML = '<span style="opacity:0.7">Sending…</span>';

  try {
    const res = await fetch(FORMSPREE_URL, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json().catch(() => ({}));

    if (res.ok) {
      // Success: hide form, show success panel
      form.style.display = 'none';
      if (successEl) { successEl.style.display = 'block'; }
    } else {
      // Formspree returned an error — show field errors if any
      btn.disabled = false;
      btn.innerHTML = origLabel;
      if (data.errors && data.errors.length) {
        data.errors.forEach(err => {
          const field = form.querySelector(`[name="${err.field}"]`);
          if (field) showFieldError(field, err.message);
          else showFormError(form, err.message);
        });
      } else {
        showFormError(form, 'Something went wrong — please try again or email <a href="mailto:elitetkdscot@gmail.com">elitetkdscot@gmail.com</a> directly.');
      }
    }
  } catch (err) {
    btn.disabled = false;
    btn.innerHTML = origLabel;
    showFormError(form, 'Network error. Please check your connection and try again.');
  }
}


// ── Show a banner error inside a form ──
function showFormError(form, message) {
  let banner = form.querySelector('.form-error-banner');
  if (!banner) {
    banner = document.createElement('div');
    banner.className = 'form-error-banner';
    form.insertBefore(banner, form.querySelector('button[type="submit"]').closest('.form-submit-row') || form.lastElementChild);
  }
  banner.innerHTML = '⚠️ ' + message;
}

// ── Scroll reveal — only animate cards that start below the fold ──
const revealEls = document.querySelectorAll('.reveal');
revealEls.forEach(el => {
  if (el.getBoundingClientRect().top > window.innerHeight) {
    el.classList.add('animate');
  }
});
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal.animate').forEach(el => observer.observe(el));

// ── Nav scroll shadow ──
window.addEventListener('scroll', () => {
  document.getElementById('navbar').style.boxShadow = window.scrollY > 60 ? '0 4px 30px rgba(0,0,0,0.45)' : 'none';
});



// ── Shop category tabs ──
function showShopCat(cat, btn) {
  document.querySelectorAll('.shop-cat-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.shop-tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('shop-cat-' + cat).classList.add('active');
  if (btn) btn.classList.add('active');
}

// ── Shop buy button - checks size selected ──
function buyProduct(url, sizeSelectId) {
  var sel = document.getElementById(sizeSelectId);
  if (sel && sel.value === '') {
    sel.style.borderColor = '#e8192e';
    sel.focus();
    return;
  }
  window.open(url, '_blank');
}


// ── Shop tabs ──
function showShopTab(id, btn) {
  document.querySelectorAll('.shop-tab-panel').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.shop-tab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('shoptab-'+id).classList.add('active');
  if (btn) btn.classList.add('active');
}

// ── Smooth scroll — handled by CSS scroll-behavior:smooth + scroll-margin-top ──
// Native CSS approach: no JS needed, works on all links including mobile menu
