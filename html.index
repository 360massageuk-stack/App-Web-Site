<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elite Scotland Taekwon-Do | Build Confidence. Get Fit. Learn Self-Defence.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@400;500;600;700&family=Barlow:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #C8102E;
    --red-bright: #E8192E;
    --red-dark: #9B0020;
    --navy: #0A1628;
    --navy-mid: #0D1F3C;
    --navy-light: #142447;
    --white: #FFFFFF;
    --off-white: #E8E8E8;
    --gray: #8899AA;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; scroll-padding-top: 80px; }
  body { background: var(--navy); color: var(--white); font-family: 'Barlow', sans-serif; overflow-x: hidden; }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(10,22,40,0.97);
    border-bottom: 2px solid var(--red);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    padding: 0 2rem; display: flex; align-items: center;
    justify-content: space-between; height: 68px; transition: box-shadow 0.3s;
  }
  .nav-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav-logo-badge {
    width: 52px; height: 52px; border-radius: 50%; flex-shrink: 0;
    overflow: hidden; box-shadow: 0 0 14px rgba(200,16,46,0.45); background: transparent;
  }
  .nav-logo-badge img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .nav-logo-text { font-family: 'Bebas Neue', sans-serif; font-size: 1.35rem; letter-spacing: 0.08em; color: var(--white); line-height: 1; }
  .nav-logo-text span { color: var(--red); }
  .nav-links { display: flex; align-items: center; gap: 0.2rem; list-style: none; }
  .nav-links a {
    text-decoration: none; color: var(--off-white); font-family: 'Oswald', sans-serif;
    font-size: 0.78rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.5rem 0.7rem; border-radius: 3px; transition: color 0.2s, background 0.2s;
  }
  .nav-links a:hover { color: var(--red-bright); background: rgba(200,16,46,0.08); }
  .nav-cta {
    background: var(--red) !important; color: var(--white) !important;
    padding: 0.45rem 1.1rem !important; border-radius: 3px !important; font-weight: 700 !important;
    box-shadow: 0 2px 12px rgba(200,16,46,0.45);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s !important;
  }
  .nav-cta:hover { background: var(--red-bright) !important; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(200,16,46,0.6) !important; }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
  .hamburger span { width: 26px; height: 2px; background: var(--white); border-radius: 2px; transition: 0.3s; }
  .mobile-menu {
    display: none; position: fixed; top: 68px; left: 0; right: 0;
    background: rgba(10,22,40,0.98); z-index: 999; padding: 1.5rem;
    border-bottom: 2px solid var(--red); flex-direction: column; gap: 0.5rem;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    text-decoration: none; color: var(--white); font-family: 'Oswald', sans-serif;
    font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.07); transition: color 0.2s;
  }
  .mobile-menu a:hover { color: var(--red); }
  .mobile-menu .mob-cta {
    background: var(--red); color: var(--white) !important; text-align: center;
    border-radius: 3px; margin-top: 0.5rem; border-bottom: none; padding: 0.9rem !important; font-weight: 700;
  }

  /* ─── HERO WITH EMBEDDED BANNER ─── */
  #home {
    position: relative;
    display: flex; flex-direction: column;
    justify-content: flex-start; align-items: stretch;
    padding-top: 68px;
    /* NO overflow:hidden — it was clipping the banner */
  }

  /* Top half: text content */
  .hero-top {
    position: relative; z-index: 3;
    display: flex; flex-direction: column; justify-content: center;
    padding: 4rem 4rem 2.5rem;
    min-height: calc(100vh - 68px - 40px); /* viewport minus nav minus location strip */
  }

  .hero-bg {
    position: absolute;
    top: 0; left: 0; right: 0;
    /* Only cover the text area, not the banner — use a tall but not infinite height */
    bottom: 0;
    background:
      linear-gradient(105deg, rgba(10,22,40,0.97) 0%, rgba(10,22,40,0.85) 50%, rgba(10,22,40,0.45) 100%),
      radial-gradient(ellipse at 80% 50%, rgba(200,16,46,0.12) 0%, transparent 60%);
    z-index: 1;
    pointer-events: none;
  }
  .hero-slash {
    position: absolute; top: 0; right: 35%; width: 6px;
    height: 100%;
    background: linear-gradient(180deg, transparent 0%, var(--red) 30%, var(--red) 70%, transparent 100%);
    opacity: 0.2; transform: skewX(-8deg); z-index: 2;
    pointer-events: none;
  }
  .hero-hex-bg {
    position: absolute; right: -5%; top: 0; width: 55%; height: 100%;
    background:
      repeating-linear-gradient(60deg, rgba(255,255,255,0.012) 0px, rgba(255,255,255,0.012) 1px, transparent 1px, transparent 30px),
      repeating-linear-gradient(120deg, rgba(255,255,255,0.012) 0px, rgba(255,255,255,0.012) 1px, transparent 1px, transparent 30px);
    z-index: 1; opacity: 0.6;
    pointer-events: none;
  }

  .hero-content { position: relative; z-index: 3; max-width: 660px; animation: heroFadeIn 0.9s ease both; }
  @keyframes heroFadeIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-family: 'Oswald', sans-serif; font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--red);
    margin-bottom: 1rem; animation: heroFadeIn 0.8s 0.1s ease both;
  }
  .hero-eyebrow::before { content: ''; display: block; width: 32px; height: 2px; background: var(--red); }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.9; letter-spacing: 0.03em; color: var(--white);
    margin-bottom: 0.3rem; animation: heroFadeIn 0.8s 0.2s ease both;
  }
  .hero-title .red { color: var(--red); }
  .hero-title-scotland {
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: 0.15em; color: var(--off-white); display: block;
    margin-bottom: 1.2rem; animation: heroFadeIn 0.8s 0.3s ease both;
  }
  .hero-tagline {
    font-size: clamp(1rem, 2vw, 1.25rem); font-style: italic;
    color: var(--off-white); margin-bottom: 0.5rem; opacity: 0.9;
    animation: heroFadeIn 0.8s 0.4s ease both;
  }
  .hero-sub {
    font-size: 0.9rem; color: var(--gray);
    margin-bottom: 2rem; animation: heroFadeIn 0.8s 0.5s ease both;
  }
  .hero-btns { display: flex; flex-wrap: wrap; gap: 1rem; animation: heroFadeIn 0.8s 0.6s ease both; }

  /* ─── BANNER ─── */
  /* Using .hero-banner-img class as requested for maximum mobile compatibility */
  .hero-banner {
    width: 100%;
    display: block;
    overflow: visible;
    background: var(--navy-mid);
    border-top: 3px solid var(--red);
    border-bottom: 3px solid var(--red);
    line-height: 0;
    position: relative;
    z-index: 3;
  }
  .hero-banner-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: center;
    max-height: none;
    /* Never hide the image — let broken image show so path problems are visible */
  }

  /* Location pills */
  .hero-locations {
    position: relative; z-index: 3;
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    padding: 1.25rem 4rem;
    background: rgba(10,22,40,0.85);
    border-bottom: 1px solid rgba(200,16,46,0.2);
    animation: heroFadeIn 0.8s 0.75s ease both;
  }
  .loc-badge {
    display: flex; align-items: center; gap: 0.4rem;
    font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--off-white);
    padding: 0.35rem 0.9rem; border: 1px solid rgba(200,16,46,0.4);
    background: rgba(200,16,46,0.1); border-radius: 2px;
  }

  /* ─── BUTTONS ─── */
  .btn-red {
    position: relative; display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--red); color: var(--white); font-family: 'Oswald', sans-serif;
    font-weight: 700; font-size: 0.95rem; letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; padding: 0.9rem 2rem;
    clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(200,16,46,0.5); cursor: pointer; border: none;
  }
  .btn-red:hover { background: var(--red-bright); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(200,16,46,0.65); }

  .btn-outline {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: transparent; color: var(--white); font-family: 'Oswald', sans-serif;
    font-weight: 600; font-size: 0.95rem; letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; padding: 0.85rem 2rem; border: 2px solid rgba(255,255,255,0.5);
    clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
    transition: border-color 0.2s, background 0.2s, transform 0.15s; cursor: pointer;
  }
  .btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,0.07); transform: translateY(-2px); }

  /* ─── SECTIONS ─── */
  section { scroll-margin-top: 80px; }
  .section-inner { max-width: 1200px; margin: 0 auto; padding: 5rem 2rem; }
  .section-label {
    font-family: 'Oswald', sans-serif; font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.25em; text-transform: uppercase; color: var(--red);
    display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.75rem;
  }
  .section-label::before { content: ''; display: block; width: 28px; height: 2px; background: var(--red); flex-shrink: 0; }
  .section-title {
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.04em; line-height: 0.95; color: var(--white); margin-bottom: 1.5rem;
  }
  .section-title .red { color: var(--red); }

  /* Top gradient line on sections */
  .section-topline::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, transparent, var(--red) 30%, var(--red-bright) 50%, var(--red) 70%, transparent);
  }

  /* ─── ABOUT ─── */
  #about { background: var(--navy-mid); }
  #about::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, transparent, var(--red) 30%, var(--red-bright) 50%, var(--red) 70%, transparent); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-text p { color: var(--off-white); font-size: 1.05rem; line-height: 1.75; margin-bottom: 1.25rem; opacity: 0.9; }
  .about-text .lead { font-size: 1.2rem; font-style: italic; color: var(--white); font-weight: 600; opacity: 1; }

  .instructor-card {
    background: linear-gradient(135deg, var(--navy-light) 0%, rgba(200,16,46,0.08) 100%);
    border: 1px solid rgba(200,16,46,0.3); border-radius: 6px; padding: 2.5rem;
    position: relative; overflow: hidden;
  }
  .instructor-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--red); }
  .instructor-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(200,16,46,0.15); border: 1px solid rgba(200,16,46,0.4);
    color: var(--red); font-family: 'Oswald', sans-serif; font-size: 0.75rem;
    letter-spacing: 0.15em; text-transform: uppercase; padding: 0.3rem 0.8rem;
    border-radius: 2px; margin-bottom: 1rem;
  }
  .instructor-card h3 { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; letter-spacing: 0.05em; color: var(--white); line-height: 0.95; margin-bottom: 0.4rem; }
  .instructor-card h3 span { display: block; font-size: 1.4rem; color: var(--off-white); opacity: 0.8; }
  .instructor-card p { color: var(--gray); font-size: 0.9rem; line-height: 1.65; margin-top: 1rem; }
  .rank-stars { display: flex; gap: 4px; margin-top: 1rem; }
  .rank-star { width: 22px; height: 22px; background: var(--red); clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%); }

  /* ─── BENEFITS ─── */
  #benefits { background: var(--navy); }
  .benefits-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
  .benefit-card {
    background: var(--navy-mid); border: 1px solid rgba(255,255,255,0.07); border-radius: 4px;
    padding: 2rem 1.75rem; position: relative; overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s; cursor: default;
  }
  .benefit-card::before {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
    background: var(--red); transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease;
  }
  .benefit-card:hover { transform: translateY(-4px); border-color: rgba(200,16,46,0.35); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }
  .benefit-card:hover::before { transform: scaleX(1); }
  .benefit-icon {
    width: 52px; height: 52px; background: rgba(200,16,46,0.15); border: 1px solid rgba(200,16,46,0.3);
    border-radius: 4px; display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem; font-size: 1.4rem;
  }
  .benefit-card h3 { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.06em; color: var(--white); margin-bottom: 0.6rem; }
  .benefit-card p { font-size: 0.88rem; color: var(--gray); line-height: 1.6; }

  /* ─── LOCATIONS / TIMETABLE ─── */
  #locations { background: var(--navy-mid); }
  #locations::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--red) 30%, var(--red-bright) 50%, var(--red) 70%, transparent); }

  /* Location tab switcher */
  .loc-tabs {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem;
  }
  .loc-tab-btn {
    font-family: 'Oswald', sans-serif; font-size: 0.9rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; background: transparent;
    color: var(--gray); border: 1px solid rgba(255,255,255,0.15);
    padding: 0.6rem 1.4rem; cursor: pointer; border-radius: 3px; transition: all 0.2s;
  }
  .loc-tab-btn.active { background: var(--red); color: var(--white); border-color: var(--red); box-shadow: 0 3px 14px rgba(200,16,46,0.4); }
  .loc-tab-btn:hover:not(.active) { border-color: var(--red); color: var(--off-white); }

  /* Location panel */
  .loc-panel { display: none; }
  .loc-panel.active { display: block; animation: panelIn 0.3s ease; }
  @keyframes panelIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .loc-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem; margin-bottom: 1.75rem;
  }
  .loc-panel-title {
    font-family: 'Bebas Neue', sans-serif; font-size: 2.4rem; letter-spacing: 0.06em; color: var(--white);
    display: flex; align-items: center; gap: 0.75rem;
  }
  .loc-panel-title svg { color: var(--red); flex-shrink: 0; }

  /* Class cards grid */
  .class-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }

  .class-card {
    background: var(--navy); border: 1px solid rgba(200,16,46,0.2);
    border-radius: 6px; overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .class-card:hover { transform: translateY(-3px); border-color: rgba(200,16,46,0.55); box-shadow: 0 10px 35px rgba(0,0,0,0.35); }

  .class-card-head {
    background: linear-gradient(135deg, rgba(200,16,46,0.18) 0%, rgba(200,16,46,0.06) 100%);
    border-bottom: 2px solid rgba(200,16,46,0.25); padding: 1rem 1.25rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .class-age-tag {
    font-family: 'Oswald', sans-serif; font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    background: var(--red); color: var(--white);
    padding: 0.25rem 0.65rem; border-radius: 2px;
  }
  .class-day {
    font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem;
    letter-spacing: 0.08em; color: var(--off-white);
  }

  .class-card-body { padding: 1.25rem; }
  .class-venue {
    font-family: 'Oswald', sans-serif; font-size: 0.95rem; font-weight: 600;
    color: var(--white); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.4rem;
  }
  .class-venue svg { color: var(--red); flex-shrink: 0; }
  .class-time {
    font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--red);
    letter-spacing: 0.05em; line-height: 1; margin-bottom: 0.3rem;
  }
  .class-desc { font-size: 0.82rem; color: var(--gray); line-height: 1.55; margin-bottom: 1.1rem; }
  .class-book-btn {
    display: block; text-align: center; background: var(--red); color: var(--white);
    font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 0.82rem;
    letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
    padding: 0.65rem 1rem; clip-path: polygon(5px 0%, 100% 0%, calc(100% - 5px) 100%, 0% 100%);
    transition: background 0.2s; cursor: pointer; border: none; width: 100%;
  }
  .class-book-btn:hover { background: var(--red-bright); }

  /* Placeholder card */
  .class-card.placeholder { border-style: dashed; opacity: 0.6; }
  .class-card.placeholder .class-card-head { background: rgba(255,255,255,0.03); border-bottom-style: dashed; }
  .class-card.placeholder .class-time { color: var(--gray); }
  .class-card.placeholder .class-age-tag { background: var(--gray); }

  /* Day group label inside location panels */
  .day-group-label {
    font-family: 'Oswald', sans-serif; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--red); margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(200,16,46,0.2);
  }

  /* Venue address line under venue name */
  .class-address {
    font-size: 0.78rem; color: var(--gray);
    line-height: 1.4; margin-bottom: 0.6rem;
    font-family: 'Barlow', sans-serif;
  }

  /* ─── KIDS / FAMILY ─── */
  #kids { background: var(--navy); }
  .kids-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .kids-big-num { font-family: 'Bebas Neue', sans-serif; font-size: clamp(6rem, 15vw, 12rem); line-height: 0.85; color: rgba(200,16,46,0.12); letter-spacing: -0.02em; user-select: none; }
  .kids-badge-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
  .kids-badge {
    background: var(--navy-light); border: 1px solid rgba(200,16,46,0.3);
    color: var(--off-white); font-family: 'Oswald', sans-serif; font-size: 0.8rem;
    font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.5rem 1rem; border-radius: 2px;
  }
  .kids-text p { color: var(--off-white); font-size: 1.05rem; line-height: 1.75; margin-bottom: 1.25rem; opacity: 0.9; }
  .age-bar {
    display: flex; align-items: center; gap: 1rem;
    background: var(--navy-light); border: 1px solid rgba(200,16,46,0.25);
    border-radius: 4px; padding: 1.25rem 1.5rem; margin-bottom: 2rem;
  }
  .age-bar-icon { font-size: 2rem; flex-shrink: 0; }
  .age-bar-text strong { display: block; font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 0.05em; color: var(--red); line-height: 1; }
  .age-bar-text span { font-size: 0.85rem; color: var(--gray); font-family: 'Oswald', sans-serif; letter-spacing: 0.08em; text-transform: uppercase; }

  /* ─── PRICING ─── */
  #pricing { background: var(--navy-mid); }
  #pricing::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--red) 30%, var(--red-bright) 50%, var(--red) 70%, transparent); }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  .pricing-card {
    background: var(--navy); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px; padding: 0; position: relative; overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
    display: flex; flex-direction: column;
  }
  .pricing-card.featured { border-color: var(--red); background: linear-gradient(160deg, var(--navy-light) 0%, rgba(200,16,46,0.05) 100%); }
  .pricing-card.featured .pricing-head { background: var(--red); }
  .pricing-card:hover { transform: translateY(-4px); border-color: rgba(200,16,46,0.5); box-shadow: 0 16px 50px rgba(0,0,0,0.35); }

  .pricing-badge {
    position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
    background: var(--white); color: var(--red-dark);
    font-family: 'Oswald', sans-serif; font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; padding: 0.3rem 1.1rem;
    border-radius: 0 0 4px 4px;
  }

  .pricing-head {
    background: rgba(200,16,46,0.1); padding: 1.75rem 2rem 1.25rem;
    border-bottom: 1px solid rgba(200,16,46,0.2);
  }
  .pricing-name {
    font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem;
    letter-spacing: 0.06em; color: var(--white); margin-bottom: 0.25rem;
  }
  .pricing-who { font-size: 0.82rem; color: var(--gray); font-family: 'Oswald', sans-serif; letter-spacing: 0.08em; text-transform: uppercase; }
  .pricing-price { display: flex; align-items: baseline; gap: 0.2rem; margin-top: 1rem; }
  .pricing-price .currency { font-size: 1.5rem; color: var(--white); align-self: flex-start; padding-top: 0.3rem; }
  .pricing-price .amount { font-family: 'Bebas Neue', sans-serif; font-size: 4rem; color: var(--white); line-height: 1; }
  .pricing-price .per { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-left: 0.2rem; }

  .pricing-body { padding: 1.75rem 2rem; flex: 1; display: flex; flex-direction: column; }

  .pricing-section-label {
    font-family: 'Oswald', sans-serif; font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--red);
    margin-bottom: 0.6rem; margin-top: 1rem;
  }
  .pricing-section-label:first-child { margin-top: 0; }

  .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.5rem; }
  .pricing-features li {
    display: flex; align-items: flex-start; gap: 0.6rem;
    font-size: 0.88rem; color: var(--off-white); line-height: 1.45;
  }
  .pricing-features li::before { content: '✓'; color: var(--red); font-weight: 700; flex-shrink: 0; margin-top: 0.05rem; }
  .pricing-features li.locked { opacity: 0.38; }
  .pricing-features li.locked::before { content: '—'; color: var(--gray); }

  .pricing-footer { margin-top: auto; padding-top: 1.5rem; }
  .btn-red-full {
    display: block; text-align: center; background: var(--red); color: var(--white);
    font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 0.9rem;
    letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
    padding: 0.9rem 1.5rem; clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
    transition: background 0.2s;
  }
  .btn-red-full:hover { background: var(--red-bright); }
  .btn-outline-full {
    display: block; text-align: center; background: transparent; color: var(--off-white);
    font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 0.9rem;
    letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
    padding: 0.9rem 1.5rem; border: 1px solid rgba(255,255,255,0.22);
    clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%); transition: border-color 0.2s, background 0.2s;
  }
  .btn-outline-full:hover { border-color: var(--white); background: rgba(255,255,255,0.05); }

  /* ─── FORMS ─── */
  #forms { background: var(--navy); }
  .forms-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 3rem; }
  .form-link-card {
    display: flex; flex-direction: column; align-items: flex-start; gap: 0.75rem;
    background: var(--navy-mid); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 6px; padding: 1.5rem; text-decoration: none; color: var(--white);
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    position: relative; overflow: hidden;
  }
  .form-link-card::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
    background: var(--red); transform: scaleX(0); transform-origin: left; transition: transform 0.3s;
  }
  .form-link-card:hover { border-color: rgba(200,16,46,0.4); background: rgba(200,16,46,0.05); transform: translateY(-3px); }
  .form-link-card:hover::after { transform: scaleX(1); }
  .form-link-icon {
    width: 48px; height: 48px; background: rgba(200,16,46,0.15);
    border: 1px solid rgba(200,16,46,0.3); border-radius: 4px;
    display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0;
  }
  .form-link-card strong { font-family: 'Oswald', sans-serif; font-size: 0.95rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--white); }
  .form-link-card span { font-size: 0.8rem; color: var(--gray); line-height: 1.5; }
  .form-link-card .flc-arrow { font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 700; color: var(--red); letter-spacing: 0.1em; text-transform: uppercase; margin-top: auto; }

  /* ─── SHOP ─── */
  #shop { background: var(--navy-mid); }
  #shop::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--red) 30%, var(--red-bright) 50%, var(--red) 70%, transparent); }
  .shop-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 3rem; }
  /* ─── SHOP ─── */
  .shop-card {
    background: var(--navy); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 6px; overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .shop-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.4); border-color: rgba(200,16,46,0.3); }
  .shop-img {
    height: 150px; background: var(--navy-light); display: flex;
    align-items: center; justify-content: center;
    border-bottom: 2px solid rgba(200,16,46,0.15);
    position: relative; overflow: hidden;
  }
  .shop-img::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(45deg, rgba(200,16,46,0.03) 0px, rgba(200,16,46,0.03) 1px, transparent 1px, transparent 18px);
  }
  .shop-info { padding: 1.25rem; display: flex; flex-direction: column; flex: 1; gap: 0.4rem; }
  .shop-category {
    font-family: 'Oswald', sans-serif; font-size: 0.65rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--red);
  }
  .shop-info h4 {
    font-family: 'Oswald', sans-serif; font-size: 1rem; font-weight: 600;
    letter-spacing: 0.04em; text-transform: uppercase; color: var(--white);
  }
  .shop-desc { font-size: 0.82rem; color: var(--gray); line-height: 1.55; flex: 1; }
  .shop-price-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 0.75rem; margin-top: 0.75rem; flex-wrap: wrap;
  }
  .shop-price { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: var(--red); letter-spacing: 0.05em; }
  .shop-btn {
    display: inline-flex; align-items: center;
    background: var(--red); color: var(--white);
    font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 0.75rem;
    letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
    padding: 0.45rem 1rem; border-radius: 3px;
    transition: background 0.2s; white-space: nowrap;
  }
  .shop-btn:hover { background: var(--red-bright); }

  /* ─── APP SUBSCRIPTION CARD ─── */
  .app-sub-card {
    background: linear-gradient(160deg, var(--navy-light) 0%, rgba(10,22,40,0.95) 100%);
    border: 1px solid rgba(200,16,46,0.35); border-radius: 10px;
    overflow: hidden; width: 100%; max-width: 340px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.45), 0 0 40px rgba(200,16,46,0.08);
  }
  .app-sub-card-top {
    background: linear-gradient(135deg, rgba(200,16,46,0.15) 0%, rgba(200,16,46,0.04) 100%);
    border-bottom: 1px solid rgba(200,16,46,0.2);
    padding: 1.75rem 1.5rem 1.5rem;
  }

  @media (max-width: 768px) {
    .app-phone-visual { display: flex; justify-content: center; }
    .app-sub-card { max-width: 100%; }
  }

  /* ─── TKD APP ─── */
  #app { background: var(--navy); }
  .app-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .app-phone-visual { display: flex; justify-content: center; align-items: flex-start; }
  .app-store-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .store-btn { display: inline-flex; align-items: center; gap: 0.7rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); color: var(--white); text-decoration: none; padding: 0.75rem 1.25rem; border-radius: 8px; transition: background 0.2s, border-color 0.2s; }
  .store-btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); }
  .store-btn-icon { font-size: 1.5rem; }
  .store-btn-label { font-size: 0.65rem; color: var(--gray); display: block; font-family: 'Oswald', sans-serif; letter-spacing: 0.1em; text-transform: uppercase; }
  .store-btn-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; letter-spacing: 0.05em; display: block; }

  /* ─── CONTACT ─── */
  #contact { background: var(--navy-mid); }
  #contact::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--red) 30%, var(--red-bright) 50%, var(--red) 70%, transparent); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; }
  .contact-info-block { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-info-item { display: flex; align-items: flex-start; gap: 1rem; }
  .contact-icon { width: 40px; height: 40px; background: rgba(200,16,46,0.15); border: 1px solid rgba(200,16,46,0.3); border-radius: 3px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
  .contact-info-item h4 { font-family: 'Oswald', sans-serif; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 0.2rem; }
  .contact-info-item p { color: var(--off-white); font-size: 0.9rem; line-height: 1.6; }
  .contact-info-item a { color: var(--off-white); text-decoration: none; }
  .contact-info-item a:hover { color: var(--red); }
  .social-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .social-btn { width: 40px; height: 40px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 3px; display: flex; align-items: center; justify-content: center; font-size: 1rem; text-decoration: none; color: var(--white); transition: background 0.2s, border-color 0.2s; }
  .social-btn:hover { background: rgba(200,16,46,0.2); border-color: var(--red); }
  .trial-form { background: var(--navy); border: 1px solid rgba(200,16,46,0.25); border-radius: 6px; padding: 2.5rem; }
  .trial-form h3 { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.05em; color: var(--white); margin-bottom: 0.4rem; }
  .trial-form > p { font-size: 0.85rem; color: var(--gray); margin-bottom: 2rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
  .form-group label { font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray); }
  .form-group input, .form-group select, .form-group textarea {
    background: var(--navy-mid); border: 1px solid rgba(255,255,255,0.1); color: var(--white);
    font-family: 'Barlow', sans-serif; font-size: 0.9rem; padding: 0.75rem 1rem;
    border-radius: 3px; outline: none; transition: border-color 0.2s; -webkit-appearance: none;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--red); }
  .form-group select option { background: var(--navy-mid); }
  .form-group textarea { resize: vertical; min-height: 90px; }

  /* ─── CTA BANNER ─── */
  #cta { background: linear-gradient(135deg, var(--red-dark) 0%, var(--red) 50%, var(--red-dark) 100%); position: relative; overflow: hidden; }
  #cta::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(-45deg, rgba(0,0,0,0.08) 0px, rgba(0,0,0,0.08) 1px, transparent 1px, transparent 20px); }
  .cta-inner { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 4.5rem 2rem; text-align: center; }
  .cta-inner h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: 0.04em; line-height: 0.9; color: var(--white); margin-bottom: 0.75rem; text-shadow: 0 2px 20px rgba(0,0,0,0.3); }
  .cta-inner p { font-size: 1.1rem; color: rgba(255,255,255,0.85); margin-bottom: 2.5rem; font-style: italic; }
  .cta-btns { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; }
  .cta-inner .cta-website { display: block; font-family: 'Oswald', sans-serif; font-size: 1rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.7); text-decoration: none; margin-top: 2rem; transition: color 0.2s; }
  .cta-inner .cta-website:hover { color: var(--white); }
  .btn-white { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--white); color: var(--red-dark); font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 0.95rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; padding: 0.9rem 2rem; clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%); transition: background 0.2s, transform 0.15s; box-shadow: 0 4px 20px rgba(0,0,0,0.2); }
  .btn-white:hover { background: var(--off-white); transform: translateY(-2px); }
  .btn-outline-white { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: var(--white); font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 0.95rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; padding: 0.9rem 2rem; border: 2px solid rgba(255,255,255,0.7); clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%); transition: all 0.2s; }
  .btn-outline-white:hover { border-color: var(--white); background: rgba(255,255,255,0.1); transform: translateY(-2px); }

  /* ─── FOOTER ─── */
  footer { background: #060E1A; border-top: 2px solid var(--red); padding: 3rem 2rem 2rem; }
  .footer-inner { max-width: 1200px; margin: 0 auto; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
  .footer-logo-text { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.08em; color: var(--white); margin-bottom: 0.75rem; }
  .footer-logo-text span { color: var(--red); }
  .footer-tagline { font-size: 0.85rem; font-style: italic; color: var(--gray); margin-bottom: 1.25rem; line-height: 1.6; }
  .footer-col h4 { font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 1rem; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-col ul a { color: var(--gray); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; }
  .footer-col ul a:hover { color: var(--white); }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.07); padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  .footer-bottom p { font-size: 0.8rem; color: var(--gray); }

  /* ─── SCROLL REVEAL ─── */
  .reveal { opacity: 1; transform: none; }
  .reveal.animate { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.animate.visible { opacity: 1; transform: none; }

  /* ─── RESPONSIVE ─── */
  /* ─── 1024px and below ─── */
  @media (max-width: 1024px) {
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
    .shop-grid { grid-template-columns: repeat(2, 1fr); }
    .pricing-grid { grid-template-columns: 1fr 1fr; }
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .forms-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ─── Tablet 768px ─── */
  @media (max-width: 768px) {
    /* Nav */
    .nav-links { display: none; }
    .hamburger { display: flex; }

    /* Hero text area */
    .hero-top {
      padding: 2rem 1.5rem 1.75rem;
      min-height: auto;
    }

    /* Banner — full width, natural height, never cropped */
    .hero-banner {
      width: 100%;
      display: block !important;
    }
    .hero-banner-img {
      display: block !important;
      width: 100% !important;
      height: auto !important;
      max-height: none !important;
      object-fit: contain !important;
      object-position: center !important;
    }

    /* Location pills */
    .hero-locations { padding: 1rem 1.5rem; gap: 0.6rem; }

    /* Grids */
    .app-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .app-phone-visual { display: flex; justify-content: center; }
    .about-grid, .kids-grid, .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    .class-cards { grid-template-columns: 1fr 1fr; }
    .benefits-grid { grid-template-columns: 1fr 1fr; }
    .shop-grid { grid-template-columns: repeat(2, 1fr); }
    .pricing-grid { grid-template-columns: 1fr; }
    .forms-grid { grid-template-columns: 1fr 1fr; }
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .form-row { grid-template-columns: 1fr; }
    .section-inner { padding: 3.5rem 1.5rem; }
  }

  @media (max-width: 540px) {
    /* Hero text */
    .hero-top { padding: 1.75rem 1.25rem 1.5rem; }
    .hero-eyebrow { font-size: 0.75rem; margin-bottom: 0.6rem; }
    .hero-title { font-size: clamp(2.8rem, 12vw, 4rem); margin-bottom: 0.2rem; }
    .hero-title-scotland { font-size: clamp(1.5rem, 7vw, 2.5rem); margin-bottom: 0.8rem; }
    .hero-tagline { font-size: 0.95rem; margin-bottom: 0.4rem; }
    .hero-sub { font-size: 0.82rem; margin-bottom: 1.5rem; }
    .hero-btns { flex-direction: column; align-items: stretch; gap: 0.75rem; }
    .hero-btns .btn-red,
    .hero-btns .btn-outline { text-align: center; justify-content: center; }

    /* Banner — explicit !important overrides for mobile as specified */
    .hero-banner { display: block !important; width: 100% !important; overflow: visible !important; }
    .hero-banner-img { display: block !important; width: 100% !important; height: auto !important; max-height: none !important; object-fit: contain !important; object-position: center !important; }

    /* Location pills */
    .hero-locations { padding: 0.9rem 1.25rem; gap: 0.5rem; }
    .loc-badge { font-size: 0.68rem; padding: 0.3rem 0.7rem; }

    /* Grids */
    .class-cards { grid-template-columns: 1fr; }
    .benefits-grid { grid-template-columns: 1fr; }
    .shop-grid { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr; }
    .forms-grid { grid-template-columns: 1fr; }
    .cta-btns { flex-direction: column; align-items: center; }

    /* Location tabs */
    .loc-tabs { gap: 0.4rem; }
    .loc-tab-btn { font-size: 0.75rem; padding: 0.5rem 0.85rem; }

    /* Pricing */
    .pricing-card { margin-bottom: 0.5rem; }
    .pricing-price .amount { font-size: 3rem; }

    /* Section spacing */
    .section-inner { padding: 2.75rem 1.25rem; }
    .section-title { font-size: clamp(2rem, 10vw, 3rem); }
  }

  /* ─── Very small phones 390px and below ─── */
  @media (max-width: 390px) {
    .hero-top { padding: 1.5rem 1rem 1.25rem; }
    .hero-title { font-size: 2.8rem; }
    .hero-title-scotland { font-size: 1.5rem; }
    .hero-banner { display: block !important; width: 100% !important; }
    .hero-banner-img { display: block !important; width: 100% !important; height: auto !important; max-height: none !important; }
    .loc-tab-btn { font-size: 0.7rem; padding: 0.45rem 0.7rem; }
    .nav-logo-text { font-size: 1.1rem; }
    .section-inner { padding: 2.5rem 1rem; }
  }
  /* ─── MODAL FORMS ─── */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 2000;
    background: rgba(6,14,26,0.92); backdrop-filter: blur(6px);
    align-items: flex-start; justify-content: center;
    padding: 1rem; overflow-y: auto;
  }
  .modal-overlay.open { display: flex; }

  .modal-box {
    background: var(--navy-mid); border: 1px solid rgba(200,16,46,0.35);
    border-radius: 8px; width: 100%; max-width: 680px;
    margin: auto; position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    animation: modalIn 0.25s ease;
  }
  @keyframes modalIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }

  .modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem 2rem; border-bottom: 1px solid rgba(200,16,46,0.2);
    background: linear-gradient(135deg, rgba(200,16,46,0.12) 0%, transparent 100%);
    border-radius: 8px 8px 0 0;
  }
  .modal-head h3 {
    font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem;
    letter-spacing: 0.06em; color: var(--white); margin: 0;
  }
  .modal-close {
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    color: var(--white); font-size: 1.2rem; width: 36px; height: 36px;
    border-radius: 50%; cursor: pointer; display: flex; align-items: center;
    justify-content: center; transition: background 0.2s; flex-shrink: 0;
    line-height: 1;
  }
  .modal-close:hover { background: var(--red); border-color: var(--red); }

  .modal-body { padding: 2rem; }

  .modal-body .form-note {
    font-size: 0.82rem; color: var(--gray); margin-bottom: 1.5rem;
    padding: 0.75rem 1rem; background: rgba(200,16,46,0.08);
    border-left: 3px solid var(--red); border-radius: 0 4px 4px 0; line-height: 1.6;
  }

  .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
  .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
  .form-group.full { grid-column: 1 / -1; }
  .form-group label {
    font-family: 'Oswald', sans-serif; font-size: 0.73rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray);
  }
  .form-group label .req { color: var(--red); margin-left: 2px; }
  .form-group input,
  .form-group select,
  .form-group textarea {
    background: rgba(10,22,40,0.8); border: 1px solid rgba(255,255,255,0.12);
    color: var(--white); font-family: 'Barlow', sans-serif; font-size: 0.9rem;
    padding: 0.75rem 1rem; border-radius: 3px; outline: none;
    transition: border-color 0.2s; -webkit-appearance: none; width: 100%;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--red); background: rgba(10,22,40,1); }
  .form-group select option { background: #0D1F3C; color: var(--white); }
  .form-group textarea { resize: vertical; min-height: 80px; }

  .consent-row {
    display: flex; align-items: flex-start; gap: 0.75rem;
    margin-bottom: 1.25rem; padding: 1rem; background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08); border-radius: 4px;
  }
  .consent-row input[type="checkbox"] {
    width: 18px; height: 18px; min-width: 18px; flex-shrink: 0;
    accent-color: var(--red); cursor: pointer; margin-top: 2px;
    padding: 0; border: none; background: none;
  }
  .consent-row label {
    font-size: 0.82rem; color: var(--gray); line-height: 1.55;
    cursor: pointer; letter-spacing: normal; text-transform: none;
    font-family: 'Barlow', sans-serif; font-weight: 400;
  }

  .form-submit-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .form-submit-row .form-note-small { font-size: 0.75rem; color: var(--gray); }

  .form-success {
    display: none; text-align: center; padding: 2rem;
  }
  .form-success .tick {
    font-size: 3rem; margin-bottom: 1rem; display: block;
  }
  .form-success h4 {
    font-family: 'Bebas Neue', sans-serif; font-size: 2rem;
    letter-spacing: 0.06em; color: var(--white); margin-bottom: 0.5rem;
  }
  .form-success p { color: var(--gray); font-size: 0.9rem; }

  /* Form link cards updated for button-trigger */
  .form-link-card { cursor: pointer; }

  @media (max-width: 540px) {
    .modal-head { padding: 1.25rem 1.5rem; }
    .modal-body { padding: 1.25rem 1.5rem; }
    .modal-head h3 { font-size: 1.4rem; }
    .form-row-2, .form-row-3 { grid-template-columns: 1fr; }
  }
  /* ─── CONTACT BIG BUTTONS ─── */
  .contact-big-btn {
    display: flex; align-items: center; gap: 1rem;
    background: var(--navy-light); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px; padding: 1.1rem 1.25rem;
    text-decoration: none; color: var(--white);
    margin-bottom: 0.75rem;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }
  .contact-big-btn:hover { border-color: rgba(200,16,46,0.45); background: rgba(200,16,46,0.06); transform: translateX(4px); }
  .contact-big-btn-red { background: var(--red); border-color: var(--red); }
  .contact-big-btn-red:hover { background: var(--red-bright); border-color: var(--red-bright); transform: translateX(4px); }
  .contact-big-btn-icon { font-size: 1.4rem; flex-shrink: 0; }
  .contact-big-btn-label { font-family: 'Oswald', sans-serif; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray); margin-bottom: 0.15rem; }
  .contact-big-btn-red .contact-big-btn-label { color: rgba(255,255,255,0.75); }
  .contact-big-btn-value { font-family: 'Oswald', sans-serif; font-size: 1rem; font-weight: 600; color: var(--white); letter-spacing: 0.03em; }
  .contact-big-btn-arrow { margin-left: auto; color: var(--red); font-size: 1.1rem; flex-shrink: 0; }
  .contact-big-btn-red .contact-big-btn-arrow { color: rgba(255,255,255,0.8); }

  /* ── Field validation errors ── */
  .field-error {
    display: block; font-size: 0.75rem; color: #e8192e;
    margin-top: 0.3rem; font-family: 'Barlow', sans-serif;
  }
  .form-group.has-error input,
  .form-group.has-error select,
  .form-group.has-error textarea,
  .consent-row.has-error input[type="checkbox"] {
    border-color: #e8192e !important;
    outline: none;
  }
  .consent-row.has-error { border-color: rgba(232,25,46,0.4); background: rgba(232,25,46,0.05); }

  /* ── Form-level error banner ── */
  .form-error-banner {
    background: rgba(232,25,46,0.1); border: 1px solid rgba(232,25,46,0.4);
    border-radius: 4px; padding: 0.75rem 1rem; margin-bottom: 1rem;
    font-size: 0.85rem; color: var(--off-white); line-height: 1.5;
  }
  .form-error-banner a { color: var(--red); }

  /* ─── APP SECTION RESPONSIVE ─── */
  @media (max-width: 768px) {
    .app-features-grid { grid-template-columns: 1fr 1fr !important; }
    .app-pricing-grid  { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 480px) {
    .app-features-grid { grid-template-columns: 1fr !important; }
  }


  /* ─── SHOP ─── */
  .shop-tab-btn {
    font-family: 'Oswald', sans-serif; font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: transparent; color: var(--gray);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.55rem 1.25rem; border-radius: 3px; cursor: pointer;
    transition: all 0.2s;
  }
  .shop-tab-btn.active, .shop-tab-btn:hover {
    background: var(--red); color: var(--white); border-color: var(--red);
  }
  .shop-cat-panel { display: none; }
  .shop-cat-panel.active { display: block; animation: panelIn 0.25s ease; }

  .shop-product-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .shop-product-card {
    background: var(--navy-mid); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px; overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    display: flex; flex-direction: column;
  }
  .shop-product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(200,16,46,0.4);
    box-shadow: 0 12px 40px rgba(0,0,0,0.35);
  }
  .shop-product-img {
    height: 260px; overflow: hidden; background: var(--navy-light);
    border-bottom: 2px solid rgba(200,16,46,0.15);
  }
  .shop-product-img img { transition: transform 0.3s; }
  .shop-product-card:hover .shop-product-img img { transform: scale(1.03); }

  .shop-product-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  .shop-product-cat {
    font-family: 'Oswald', sans-serif; font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--red);
  }
  .shop-product-name {
    font-family: 'Bebas Neue', sans-serif; font-size: 1.7rem;
    letter-spacing: 0.04em; color: var(--white); line-height: 1;
  }
  .shop-product-desc { font-size: 0.85rem; color: var(--gray); line-height: 1.6; flex: 1; }
  .shop-product-price {
    font-family: 'Bebas Neue', sans-serif; font-size: 2rem;
    color: var(--red); letter-spacing: 0.03em; margin-top: 0.25rem;
  }
  .shop-product-size-row {
    display: flex; align-items: center; gap: 0.75rem; margin-top: 0.25rem;
  }
  .shop-size-label {
    font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray);
    flex-shrink: 0;
  }
  .shop-size-select {
    flex: 1; background: var(--navy); border: 1px solid rgba(255,255,255,0.15);
    color: var(--white); font-family: 'Barlow', sans-serif; font-size: 0.9rem;
    padding: 0.6rem 0.9rem; border-radius: 3px; outline: none; cursor: pointer;
    -webkit-appearance: none; transition: border-color 0.2s;
  }
  .shop-size-select:focus { border-color: var(--red); }
  .shop-size-select option { background: var(--navy-mid); }

  .shop-buy-btn {
    display: block; text-align: center; width: 100%;
    background: var(--red); color: var(--white);
    font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 0.95rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; padding: 0.9rem 1.5rem;
    border: none; border-radius: 4px; cursor: pointer; margin-top: 0.75rem;
    transition: background 0.2s, transform 0.15s;
  }
  .shop-buy-btn:hover { background: var(--red-bright); transform: translateY(-2px); }

  @media (max-width: 540px) {
    .shop-product-img { height: 200px; }
  }


  /* ─── SHOPPING CART ─── */
  .cart-icon-btn {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 900;
    background: var(--red); color: var(--white);
    width: 60px; height: 60px; border-radius: 50%; border: none;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; cursor: pointer;
    box-shadow: 0 4px 20px rgba(200,16,46,0.6);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .cart-icon-btn:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(200,16,46,0.7); }
  .cart-badge {
    position: absolute; top: -4px; right: -4px;
    background: var(--white); color: var(--red-dark);
    font-family: 'Oswald', sans-serif; font-size: 0.7rem; font-weight: 700;
    width: 20px; height: 20px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    display: none;
  }

  .cart-drawer {
    position: fixed; right: 0; top: 0; bottom: 0; width: 420px; max-width: 100vw;
    background: var(--navy-mid); z-index: 1500;
    transform: translateX(100%); transition: transform 0.3s ease;
    display: flex; flex-direction: column;
    border-left: 2px solid rgba(200,16,46,0.3);
    box-shadow: -10px 0 40px rgba(0,0,0,0.5);
  }
  .cart-drawer.open { transform: translateX(0); }
  .cart-backdrop {
    position: fixed; inset: 0; background: rgba(0,0,0,0.6);
    z-index: 1499; display: none;
  }
  .cart-backdrop.open { display: block; }

  .cart-header {
    padding: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(135deg, rgba(200,16,46,0.12), transparent);
    flex-shrink: 0;
  }
  .cart-header h3 {
    font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem;
    letter-spacing: 0.06em; color: var(--white); margin: 0;
  }
  .cart-close-btn {
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    color: var(--white); width: 36px; height: 36px; border-radius: 50%;
    cursor: pointer; font-size: 1.1rem; display: flex;
    align-items: center; justify-content: center; transition: background 0.2s;
  }
  .cart-close-btn:hover { background: var(--red); border-color: var(--red); }

  .cart-items { flex: 1; overflow-y: auto; padding: 1rem 1.5rem; }

  .cart-empty {
    text-align: center; padding: 3rem 1rem; color: var(--gray);
    font-size: 0.95rem; line-height: 1.7;
  }
  .cart-empty-icon { font-size: 3rem; display: block; margin-bottom: 1rem; }

  .cart-item {
    display: flex; gap: 1rem; align-items: flex-start;
    padding: 1rem 0; border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .cart-item-details { flex: 1; }
  .cart-item-name {
    font-family: 'Oswald', sans-serif; font-size: 0.95rem; font-weight: 600;
    color: var(--white); margin-bottom: 0.2rem;
  }
  .cart-item-size { font-size: 0.8rem; color: var(--gray); margin-bottom: 0.35rem; }
  .cart-item-price { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; color: var(--red); }
  .cart-item-remove {
    background: none; border: none; color: var(--gray); cursor: pointer;
    font-size: 1rem; padding: 0.25rem; transition: color 0.2s; flex-shrink: 0;
  }
  .cart-item-remove:hover { color: var(--red); }

  .cart-footer {
    padding: 1.5rem; border-top: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0; background: var(--navy);
  }
  .cart-total-row {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 1.5rem;
  }
  .cart-total-label {
    font-family: 'Oswald', sans-serif; font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray);
  }
  .cart-total-amount {
    font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; color: var(--white); letter-spacing: 0.03em;
  }

  .cart-checkout-note {
    font-size: 0.78rem; color: var(--gray); text-align: center;
    margin-top: 0.75rem; line-height: 1.55;
  }

  .cart-added-toast {
    position: fixed; bottom: 5rem; right: 1.5rem; z-index: 1600;
    background: #22863a; color: white;
    font-family: 'Oswald', sans-serif; font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.75rem 1.25rem; border-radius: 6px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    transform: translateY(80px); opacity: 0;
    transition: transform 0.3s, opacity 0.3s; pointer-events: none;
  }
  .cart-added-toast.show { transform: translateY(0); opacity: 1; }

  @media (max-width: 480px) {
    .cart-drawer { width: 100vw; }
  }


  /* ─── SHOP CARDS ─── */
  .shop-tab-btn { font-family:'Oswald',sans-serif; font-size:0.85rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; background:transparent; color:var(--gray); border:1px solid rgba(255,255,255,0.12); padding:0.55rem 1.25rem; border-radius:3px; cursor:pointer; transition:all 0.2s; }
  .shop-tab-btn.active, .shop-tab-btn:hover { background:var(--red); color:var(--white); border-color:var(--red); }
  .shop-tab-panel { display:none; }
  .shop-tab-panel.active { display:block; }
  .shop-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1.5rem; }
  .shop-card { background:var(--navy-mid); border:1px solid rgba(255,255,255,0.08); border-radius:8px; overflow:hidden; display:flex; flex-direction:column; transition:transform 0.2s,border-color 0.2s; }
  .shop-card:hover { transform:translateY(-4px); border-color:rgba(200,16,46,0.4); }
  .shop-card-img { height:220px; background:var(--navy-light); overflow:hidden; }
  .shop-card-body { padding:1.25rem; display:flex; flex-direction:column; flex:1; gap:0.4rem; }
  .shop-card-cat { font-family:'Oswald',sans-serif; font-size:0.65rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:var(--red); }
  .shop-card-name { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:0.04em; color:var(--white); line-height:1.1; }
  .shop-card-desc { font-size:0.83rem; color:var(--gray); line-height:1.6; flex:1; }
  .shop-card-price { font-family:'Bebas Neue',sans-serif; font-size:1.8rem; color:var(--red); }
  .shop-card-btn { display:block; text-align:center; background:var(--red); color:var(--white); text-decoration:none; font-family:'Oswald',sans-serif; font-weight:700; font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; padding:0.8rem; border-radius:4px; transition:background 0.2s; margin-top:0.5rem; }
  .shop-card-btn:hover { background:#e8192e; }
</style>
</head>
<body>

<!-- ═══════════════════════════════ NAV ═══════════════════════════════ -->


<nav id="navbar">
  <a href="#home" class="nav-logo">
    <div class="nav-logo-badge">
      <img src="https://static.wixstatic.com/media/c5688d_65f276950d314bcdae9cc09df5fe62fc~mv2.png/v1/crop/x_330,y_409,w_1340,h_1196/fill/w_200,h_200,al_c,q_90,enc_avif/2-01_edited.png" alt="Elite TKD Badge"
        onerror="this.style.display='none';this.parentElement.style.cssText='width:52px;height:52px;border-radius:50%;border:2px solid #C8102E;background:radial-gradient(circle,#1a3a6e,#0A1628);display:flex;align-items:center;justify-content:center;font-family:Bebas Neue,sans-serif;font-size:0.7rem;color:white;text-align:center;line-height:1.1;';">
    </div>
    <div class="nav-logo-text">ELITE <span>SCOTLAND</span></div>
  </a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#locations">Classes</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#forms">Forms</a></li>
    <li><a href="#shop">Shop</a></li>
    <li><a href="#app">TKD App</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="#" onclick="event.preventDefault();openModal('modal-trial')" class="nav-cta">Book Free Trial</a></li>
  </ul>
  <div class="hamburger" id="hamburger" onclick="toggleMenu()">
    <span></span><span></span><span></span>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="#about" onclick="closeMenu()">About</a>
  <a href="#locations" onclick="closeMenu()">Classes &amp; Timetables</a>
  <a href="#pricing" onclick="closeMenu()">Pricing</a>
  <a href="#forms" onclick="closeMenu()">Forms</a>
  <a href="#shop" onclick="closeMenu()">Shop</a>
  <a href="#app" onclick="closeMenu()">TKD App</a>
  <a href="#contact" onclick="closeMenu()">Contact</a>
  <a href="#" class="mob-cta" onclick="closeMenu();openModal('modal-trial')">📋 Book Your Free Trial</a>
</div>

<!-- ═══════════════ HERO (banner embedded inside) ═══════════════ -->
<section id="home">
  <!-- Background decorations -->
  <div class="hero-bg"></div>
  <div class="hero-hex-bg"></div>
  <div class="hero-slash"></div>

  <!-- Text content -->
  <div class="hero-top">
    <div class="hero-content">
      <div class="hero-eyebrow">ITF Taekwon-Do · Scotland</div>
      <h1 class="hero-title">ELITE<br><span class="red">TAEKWON-DO</span></h1>
      <span class="hero-title-scotland">SCOTLAND</span>
      <p class="hero-tagline">Build confidence. Get fit. Learn self-defence.</p>
      <p class="hero-sub">Age 3 to Adult &nbsp;·&nbsp; All abilities welcome &nbsp;·&nbsp; Beginners welcome</p>
      <div class="hero-btns">
        <a href="#" onclick="event.preventDefault();openModal('modal-trial')" class="btn-red">📋 Book Your Free Trial</a>
        <a href="#locations" class="btn-outline">View Classes ↓</a>
      </div>
    </div>
  </div>

  <!-- ═══ BANNER — fbelitebanner.png must be in the same folder as this HTML file ═══ -->
  <div class="hero-banner">
    <img class="hero-banner-img" src="fbelitebanner.png" alt="Elite Scotland Taekwon-Do" style="display:block;width:100%;height:auto;">
  </div>

  <!-- Location pills below banner -->
  <div class="hero-locations">
    <div class="loc-badge">
      <svg width="9" height="13" viewBox="0 0 10 14" fill="none"><path d="M5 0C2.24 0 0 2.24 0 5c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5zm0 6.75A1.75 1.75 0 113.25 5 1.75 1.75 0 015 6.75z" fill="#C8102E"/></svg>
      Midlothian
    </div>
    <div class="loc-badge">
      <svg width="9" height="13" viewBox="0 0 10 14" fill="none"><path d="M5 0C2.24 0 0 2.24 0 5c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5zm0 6.75A1.75 1.75 0 113.25 5 1.75 1.75 0 015 6.75z" fill="#C8102E"/></svg>
      Edinburgh
    </div>
    <div class="loc-badge">
      <svg width="9" height="13" viewBox="0 0 10 14" fill="none"><path d="M5 0C2.24 0 0 2.24 0 5c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5zm0 6.75A1.75 1.75 0 113.25 5 1.75 1.75 0 015 6.75z" fill="#C8102E"/></svg>
      East Lothian
